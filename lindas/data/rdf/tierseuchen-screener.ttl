    ts:sourcePublisher "PADI-web" ;
    ts:sourceRetrievedAt "2026-05-28T19:53:43.947301+00:00"^^xsd:dateTime ;
    ts:sourceURL "https://afludiary.blogspot.com/2026/05/eurosurveillance-cross-reactive-human.html"^^xsd:anyURI .

